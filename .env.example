# ─── DealBot AI — Environment Variables ─────────────────────────────────────
# Copy this file to .env and fill in your keys.
# cp .env.example .env

# ─── Web Search API Keys ──────────────────────────────────────────────────────
# All have generous FREE tiers — no credit card required for the free tier.

# SerpAPI — 100 free searches/month, no credit card needed
# Sign up at: https://serpapi.com
# Dashboard → API Key  (copy the long hex string)
SERPAPI_KEY=your_serpapi_key_here

# Google Custom Search — 100 free searches/day
# Step 1 – Create a Search Engine:
#   https://programmablesearch.google.com → New Search Engine
#   → Set "Search the entire web": ON
#   → Copy the "Search engine ID (cx)" shown on the Overview page → paste below
# Step 2 – Get an API Key:
#   https://console.cloud.google.com → APIs & Services → Library
#   → Search "Custom Search JSON API" → Enable it
#   → APIs & Services → Credentials → Create Credentials → API key → copy below
GOOGLE_CSE_KEY=your_google_api_key_here
GOOGLE_CSE_ID=your_cx_id_here

# ─── Auth & Security ──────────────────────────────────────────────────────────
# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-generate-a-real-random-secret

# Google OAuth (for social login)
# https://console.cloud.google.com → APIs → OAuth2 credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── Blockchain (optional) ────────────────────────────────────────────────────
# Ethereum / WeilChain node URL (leave as default for local simulation)
WEB3_PROVIDER_URL=http://127.0.0.1:8545

# ─── App Settings ─────────────────────────────────────────────────────────────
DEBUG=true
FRONTEND_URL=http://localhost:3000
